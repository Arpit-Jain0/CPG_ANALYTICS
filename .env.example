# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cpg_analytics
POSTGRES_USER=cpg
POSTGRES_PASSWORD=changeme

# Convenience DSN (constructed from above in docker-compose; override if needed)
# DATABASE_URL=postgresql+psycopg2://cpg:changeme@localhost:5432/cpg_analytics

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO

# ── Data paths (defaults match repo layout; override for custom mounts) ─────
DATA_INPUT_HISTORICAL=data/input/historical
DATA_INPUT_INCREMENTAL=data/input/incremental
DATA_OUTPUT_PROCESSED=data/output/processed
DATA_OUTPUT_QUALITY_REPORTS=data/output/quality_reports
DATA_OUTPUT_ARCHIVE=data/output/archive

# ── Ingestion pipeline config ────────────────────────────────────────────────
# Path to config/ingestion.yaml (relative to repo root or absolute).
# Edit the YAML to add/remove files, toggle sheets, change loaders, etc.
# without touching Python code.
INGESTION_CONFIG=config/ingestion.json

# ── Ollama LLM ───────────────────────────────────────────────────────────────
# Ollama runs locally and needs no API key. The URL below works for local dev.
# In Docker Compose OLLAMA_BASE_URL is automatically set to http://ollama:11434/v1.
# Change OLLAMA_MODEL to any model you have pulled (e.g. mistral, phi3:mini).
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── Streamlit UI ─────────────────────────────────────────────────────────────
# URL of the FastAPI service — the UI talks ONLY to this; never directly to DB.
# In Docker Compose this is overridden to http://api:8000 automatically.
API_BASE_URL=http://localhost:8000
